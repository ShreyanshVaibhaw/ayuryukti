# AyurYukti Environment Configuration
# Copy this to .env and fill in the values

PROJECT_NAME=AyurYukti
PROJECT_SANSKRIT=आयुर्युक्ति
TAGLINE=From Voice to Verdict — Intelligent AYUSH Healthcare

# LLM (Ollama)
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_HOST=localhost
OLLAMA_PORT=11434

# Neo4j Knowledge Graph
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme_neo4j_password

# PostgreSQL Outcome Database
POSTGRES_DB=ayuryukti
POSTGRES_USER=ayuryukti
POSTGRES_PASSWORD=changeme_postgres_password
POSTGRES_URI=postgresql://ayuryukti:changeme_postgres_password@localhost:5432/ayuryukti

# Qdrant Vector Database
QDRANT_HOST=localhost
QDRANT_PORT=6333
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Bhashini Speech API (Government)
BHASHINI_API_URL=https://meity-auth.ulcacontrib.org
BHASHINI_INFERENCE_URL=https://dhruva-api.bhashini.gov.in
BHASHINI_API_KEY=

# JWT Authentication (API)
JWT_SECRET_KEY=changeme_jwt_secret_key_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# Logging
AYURYUKTI_LOG_LEVEL=INFO
